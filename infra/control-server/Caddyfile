# Caddy reverse proxy for the RMG Creator OS control server.
# Auto-TLS via Let's Encrypt. Set the ACME email below.
{
	email admin@rmasters.group
}

rmg-creator-os.rmasters.group {
	encode zstd gzip

	# Gateway / orchestrator API
	handle_path /api/* {
		reverse_proxy gateway:8080
	}

	# ALLEN — AI scriptwriting service (path stripped → /draft, /speak, /health).
	# NOTE: this exposes ALLEN's endpoints publicly; add an API-key/auth guard
	# before relying on it externally (credit-drain risk on /draft and /speak).
	handle_path /allen/* {
		reverse_proxy allen:8090
	}

	# Dashboard (everything else)
	handle {
		reverse_proxy dashboard:80
	}
}
