# Control server secrets/config. Copy to .env on the server; never commit .env.

# Strong DB password. Generate: openssl rand -base64 32
POSTGRES_PASSWORD=change-me-strong-random

# Strong Redis password. Generate: openssl rand -base64 32
REDIS_PASSWORD=change-me-strong-random

# The control server's Tailscale IP (100.x.y.z). Postgres/Redis bind here only,
# so the render node can reach them over the tailnet but the public internet cannot.
TAILSCALE_IP=100.x.y.z

# Image tag for app services once they exist.
IMAGE_TAG=latest

# HeyGen avatar-video API key (from your HeyGen account → Settings → API).
# Leave blank to disable HeyGen endpoints (gateway returns 503 for them).
HEYGEN_API_KEY=

# ElevenLabs API key (voice cloning + TTS).
ELEVENLABS_API_KEY=

# Google Drive upload (reuses the rclone Drive OAuth client + refresh token).
# Generated credentials; auto-saves completed videos into VIDEO_PRODUCTION.
GDRIVE_CLIENT_ID=
GDRIVE_CLIENT_SECRET=
GDRIVE_REFRESH_TOKEN=
GDRIVE_VIDEO_FOLDER_ID=1cQDK4jIsCxD8DCAMm7L6cfOft2pwGdEB

# Atelier delivery folders (My Poster + Final Cut — contract 06, 18, 19).
# All in rahm@rmasters.group Drive.
ATELIER_THUMBNAIL_APPROVED_ID=13RjM4TBQANfj-2s_jfMI9vKwPpRgYTuN  # cover thumbnails — approved
ATELIER_THUMBNAIL_ARCHIVED_ID=   # replaced/archived covers
ATELIER_FINAL_FOLDER_ID=         # CapCut final cut uploads

# Postiz — self-hosted social scheduling (social.rmasters.group).
# API key from Postiz Settings → API keys. Leave blank to disable social publishing.
POSTIZ_API_KEY=
POSTIZ_API_URL=https://social.rmasters.group/api/public/v1

# ALLEN AI service — required for briefings, script drafting, topic generation, voice direction.
# Anthropic API key (console.anthropic.com → API Keys). Must be in Doppler master-atelier/prd.
ANTHROPIC_API_KEY=
# Optional: override the default model (defaults to claude-sonnet-4-6 in docker-compose.yml).
ANTHROPIC_MODEL=

# ALLEN service keys
ALLEN_API_KEY=       # guards credit-consuming ALLEN endpoints; generate: openssl rand -hex 32
ADMIN_API_KEY=       # guards /projects admin routes on ALLEN

# ALLEN voice (ElevenLabs voice ID for ALLEN's spoken output — separate from production TTS).
ALLEN_VOICE_ID=

# ALLEN Google Drive (scripts folder — where drafted scripts are written).
GDRIVE_SCRIPTS_FOLDER_ID=
